@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>

    <button id="loadBtn" class="btn btn-primary">Load Podcasts</button>

    <ul id="podcastList"></ul>
</div>

@section Scripts {
    <script>
        document.getElementById("loadBtn").addEventListener("click", async () => {
            try {
                // Replace with your external API endpoint
                const response = await fetch("http://localhost:5236/podcasts");

                if (!response.ok) {
                    throw new Error("Network response was not ok");
                }

                const podcasts = await response.json();

                const list = document.getElementById("podcastList");
                list.innerHTML = ""; // clear existing items

                podcasts.forEach(podcast => {
                    const li = document.createElement("li");
                    li.textContent = podcast;
                    list.appendChild(li);
                });
            } catch (error) {
                console.error("Error fetching podcasts:", error);
            }
        });
    </script>
}
